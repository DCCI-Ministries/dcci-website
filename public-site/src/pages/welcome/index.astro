---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getWelcomePageContent } from '../../lib/firestore';
import { generateMetaTags, generateJSONLD, absoluteUrl } from '../../lib/seo';

const welcome = await getWelcomePageContent();
const canonicalUrl = absoluteUrl('/welcome/');

const seoData = {
  title: welcome.seoTitle,
  description: welcome.seoDescription,
  canonicalUrl,
  type: 'website' as const
};

const metaTags = generateMetaTags(seoData);
const jsonLd = generateJSONLD(seoData);
---

<SiteLayout
  title={welcome.seoTitle}
  description={welcome.seoDescription}
  metaTags={metaTags}
  jsonLd={jsonLd}
>
  <main>
    <div class="cta-box">
      <h2>Use the Interactive Site</h2>
      <p>For the full interactive experience with articles, videos, contact forms, and more features, visit our interactive site:</p>
      <a href="/app/welcome" class="cta-button">Open Interactive Site</a>
    </div>

    <h1>{welcome.heroTitle}</h1>
    <p class="tagline">{welcome.heroSubtitle}</p>
    <p class="tagline-sub">{welcome.headerTagline}</p>

    <section class="mission-section">
      <h2>{welcome.missionHeading}</h2>
      <div set:html={welcome.missionContent} />
    </section>

    <section class="social-section">
      <h2>{welcome.socialHeading}</h2>
      <div set:html={welcome.socialContent} />
    </section>

    <section class="support-section">
      <h2>{welcome.supportHeading}</h2>
      <div set:html={welcome.supportContent} />
    </section>

    <section class="testimony-section">
      <h2>Our Foundation</h2>
      <p class="testimony-statement"><strong>{welcome.testimonyStatement}</strong></p>
      <div class="testimony-verse" set:html={welcome.testimonyVerse.startsWith('<') ? welcome.testimonyVerse : `<p>${welcome.testimonyVerse}</p>`} />
    </section>
    <style>
      .tagline {
        font-size: 1.5rem;
        font-weight: 600;
        color: #0066cc;
        margin-bottom: 0.5rem;
      }

      .tagline-sub {
        font-size: 1.2rem;
        color: #666;
        margin-bottom: 2rem;
      }

      .mission-section,
      .social-section,
      .support-section {
        margin-top: 2rem;
      }

      .testimony-section {
        margin-top: 2rem;
        padding: 1.5rem;
        background: #f9f9f9;
        border-left: 4px solid #0066cc;
        border-radius: 4px;
      }

      .testimony-statement {
        font-size: 1.5rem;
        font-weight: bold;
        color: #0066cc;
        margin-bottom: 1rem;
      }

      .testimony-verse {
        font-style: italic;
        color: #666;
      }
    </style>
  </main>
</SiteLayout>
