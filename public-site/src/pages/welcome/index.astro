---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getWelcomePageContent } from '../../lib/firestore';
import { generateMetaTags, generateJSONLD, absoluteUrl } from '../../lib/seo';

const welcome = await getWelcomePageContent();
const canonicalUrl = absoluteUrl('/welcome/');

const seoData = {
  title: welcome.seoTitle,
  description: welcome.seoDescription,
  canonicalUrl,
  type: 'website' as const
};

const metaTags = generateMetaTags(seoData);
const jsonLd = generateJSONLD(seoData);
---

<SiteLayout
  title={welcome.seoTitle}
  description={welcome.seoDescription}
  metaTags={metaTags}
  jsonLd={jsonLd}
>
  <main>
    <div class="cta-box">
      <h2>Use the Interactive Site</h2>
      <p>For the full interactive experience with articles, videos, contact forms, and more features, visit our interactive site:</p>
      <a href="/app/welcome" class="cta-button">Open Interactive Site</a>
    </div>

    <header class="welcome-header">
      <img
        src={welcome.logoImageUrl}
        alt="DCCI Ministries logo"
        class="brand-logo"
        width="120"
        height="120"
      />
      <p class="tagline-sub">{welcome.headerTagline}</p>
    </header>

    <h1>{welcome.heroTitle}</h1>
    <p class="tagline">{welcome.heroSubtitle}</p>

    <div class="hero-image-container">
      <img
        src={welcome.heroImageUrl}
        alt="DCCI Ministries hero image representing our mission to defend Christ and critique Islam through respectful dialogue"
        class="hero-image"
      />
    </div>

    <section class="mission-section">
      <h2>{welcome.missionHeading}</h2>
      <div class="rich-content" set:html={welcome.missionContent} />
    </section>

    <section class="social-section">
      <h2>{welcome.socialHeading}</h2>
      <div class="rich-content" set:html={welcome.socialContent} />
      {welcome.socialLinks.length > 0 && (
        <ul class="link-list">
          {welcome.socialLinks.map((link) => (
            <li><a href={link.url} rel="noopener noreferrer">{link.label}</a></li>
          ))}
        </ul>
      )}
    </section>

    <section class="support-section">
      <h2>{welcome.supportHeading}</h2>
      <div class="rich-content" set:html={welcome.supportContent} />
      {welcome.supportLinks.length > 0 && (
        <ul class="link-list">
          {welcome.supportLinks.map((link) => (
            <li><a href={link.url} rel="noopener noreferrer">{link.label}</a></li>
          ))}
        </ul>
      )}
    </section>

    <section class="testimony-section">
      <h2>Our Foundation</h2>
      <p class="testimony-statement"><strong>{welcome.testimonyStatement}</strong></p>
      <div class="testimony-verse rich-content" set:html={welcome.testimonyVerse.startsWith('<') ? welcome.testimonyVerse : `<p>${welcome.testimonyVerse}</p>`} />
    </section>
    <style>
      .welcome-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
        text-align: center;
      }

      .brand-logo {
        width: 120px;
        height: 120px;
        object-fit: contain;
        filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.15));
      }

      .hero-image-container {
        margin: 2rem 0;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
      }

      .hero-image {
        width: 100%;
        height: auto;
        display: block;
        object-fit: contain;
      }

      .rich-content :global(img) {
        max-width: 100%;
        height: auto;
        display: block;
        margin: 1rem auto;
        border-radius: 8px;
      }

      .tagline {
        font-size: 1.5rem;
        font-weight: 600;
        color: #0066cc;
        margin-bottom: 0.5rem;
      }

      .tagline-sub {
        font-size: 1.2rem;
        color: #666;
        margin-bottom: 2rem;
      }

      .mission-section,
      .social-section,
      .support-section {
        margin-top: 2rem;
      }

      .link-list {
        list-style: none;
        padding: 0;
        margin: 1rem 0 0;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .link-list a {
        color: #0066cc;
        font-weight: 600;
        text-decoration: none;
      }

      .link-list a:hover {
        text-decoration: underline;
      }

      .testimony-section {
        margin-top: 2rem;
        padding: 1.5rem;
        background: #f9f9f9;
        border-left: 4px solid #0066cc;
        border-radius: 4px;
      }

      .testimony-statement {
        font-size: 1.5rem;
        font-weight: bold;
        color: #0066cc;
        margin-bottom: 1rem;
      }

      .testimony-verse {
        font-style: italic;
        color: #666;
      }
    </style>
  </main>
</SiteLayout>
